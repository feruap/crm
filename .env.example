# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myalice_clone
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── Server ───────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Meta (Facebook / Instagram) ──────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=

# ─── WhatsApp Cloud API ────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── WooCommerce ──────────────────────────────────────────
WC_URL=https://tu-tienda.com
WC_KEY=ck_
WC_SECRET=cs_
# Must match MYALICE_SECRET in wp-config.php (enables multi-product cart links)
WP_MYALICE_SECRET=

# ─── AI Providers ─────────────────────────────────────────
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=

# ─── TikTok for Business ───────────────────────────────────
TIKTOK_APP_SECRET=

# ─── Google Ads Conversions API ────────────────────────────
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CONVERSION_ACTION_ID=

# ─────────────────────────────────────────────
# CRM Boton Medico — Server Environment Variables
# Copy this to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production
PUBLIC_URL=https://api-crm.botonmedico.com
NEXT_PUBLIC_WEB_URL=https://crm.botonmedico.com

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/crm_botonmedico

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ─── WooCommerce REST API ───────────────────
WC_STORE_URL=https://tst.amunet.com.mx
WC_CONSUMER_KEY=ck_xxx
WC_CONSUMER_SECRET=cs_xxx

# ─── WhatsApp Cloud API ────────────────────
# (also in .env.whatsapp — either file works)
WHATSAPP_PHONE_NUMBER_ID=956844914189695
WHATSAPP_ACCESS_TOKEN=SYSTEM_USER_TOKEN_HERE
WHATSAPP_WABA_ID=1521810052698130
META_APP_ID=1452652589836082
META_APP_SECRET=YOUR_APP_SECRET
META_VERIFY_TOKEN=amunet_crm_webhook_verify_2026

# ─── Facebook CAPI (Conversions API) ───────
META_PIXEL_ID=YOUR_PIXEL_ID
META_CAPI_ACCESS_TOKEN=YOUR_CAPI_TOKEN

# ─── Google Ads Conversion API ─────────────
GOOGLE_ADS_CUSTOMER_ID=xxx-xxx-xxxx
GOOGLE_ADS_CONVERSION_ACTION_ID=YOUR_CONVERSION_ACTION
GOOGLE_ADS_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
GOOGLE_ADS_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GOOGLE_ADS_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_DEV_TOKEN

# ─── AI Providers (configurables en /api/settings/ai) ─
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=

# ─── Redis (for BullMQ workers) ────────────
REDIS_URL=redis://localhost:6379

{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --testPathPattern=src/__tests__ --forceExit",
    "test:watch": "jest --testPathPattern=src/__tests__ --watch",
    "test:stress": "jest --testPathPattern=llm-stress --forceExit --verbose"
  },
  "type": "commonjs",
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.19.0",
    "socket.io": "^4.7.5",
    "zhipuai": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false,
            "esModuleInterop": true
          }
        }
      ]
    },
    "testTimeout": 15000
  }
}
